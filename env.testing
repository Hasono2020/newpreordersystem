APP_NAME="PreOrder System (Testing)"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://newpreordersystem.test

# ── Use a SEPARATE MySQL database for tests ───────────────────────────
# This prevents tests from wiping your production data.
# Create this DB manually first:
#   CREATE DATABASE newpreordersystem_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=newpreordersystem_test
DB_USERNAME=root
DB_PASSWORD=

# ── Test-safe settings ────────────────────────────────────────────────
CACHE_STORE=array
SESSION_DRIVER=database
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
BCRYPT_ROUNDS=4
